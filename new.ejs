<section class="form-card">
  <h1>Add New Movie</h1>
  <p class="muted">Only logged in users can add a movie.</p>

  <%- include('../partials/errors', { errors }) %>

  <form action="/movies" method="POST" class="form-grid two-col">
    <label>
      Movie Name
      <input type="text" name="name" value="<%= old.name || '' %>" placeholder="e.g. Interstellar" />
    </label>

    <label>
      Release Year
      <input type="number" name="year" value="<%= old.year || '' %>" placeholder="e.g. 2014" />
    </label>

    <label class="full-width">
      Description
      <textarea name="description" rows="5" placeholder="Write a short movie description"><%= old.description || '' %></textarea>
    </label>

    <label>
      Genres
      <input type="text" name="genres" value="<%= old.genres || '' %>" placeholder="Drama, Sci-Fi, Adventure" />
    </label>

    <label>
      Rating (0 - 10)
      <input type="number" step="0.1" min="0" max="10" name="rating" value="<%= old.rating || '' %>" placeholder="e.g. 8.7" />
    </label>

    <label class="full-width">
      Poster URL (optional)
      <input type="url" name="posterUrl" value="<%= old.posterUrl || '' %>" placeholder="Paste an image URL" />
    </label>

    <div class="full-width">
      <button type="submit" class="btn btn-primary">Add Movie</button>
    </div>
  </form>
</section>
