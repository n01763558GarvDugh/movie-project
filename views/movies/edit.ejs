<section class="form-card">
  <h1>Edit Movie</h1>

  <%- include('../errors', { errors }) %>

  <form action="/movies/<%= movie._id %>?_method=PUT" method="POST" class="form-grid">
    <label>
      Movie Name
      <input type="text" name="name" value="<%= old.name %>" />
    </label>

    <label>
      Description
      <textarea name="description"><%= old.description %></textarea>
    </label>

    <label>
      Year
      <input type="number" name="year" value="<%= old.year %>" />
    </label>

    <label>
      Genres
      <input type="text" name="genres" value="<%= old.genres %>" />
    </label>

    <label>
      Rating
      <input type="number" step="0.1" name="rating" value="<%= old.rating %>" />
    </label>

    <label>
      Poster URL
      <input type="url" name="posterUrl" value="<%= old.posterUrl %>" />
    </label>

    <button type="submit" class="btn btn-primary">Update Movie</button>
  </form>
</section>
