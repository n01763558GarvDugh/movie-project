<section class="details-grid">
  <div>
    <img src="<%= movie.posterUrl %>" alt="<%= movie.name %> poster" class="details-image" />
  </div>

  <div class="details-card">
    <div class="movie-topline">
      <h1><%= movie.name %></h1>
      <span class="badge"><%= movie.rating %>/10</span>
    </div>

    <p class="muted"><strong>Year:</strong> <%= movie.year %></p>
    <p class="muted"><strong>Genres:</strong> <%= movie.genres.join(', ') %></p>
    <p class="muted"><strong>Added by:</strong> <%= movie.owner?.name || 'Unknown User' %></p>

    <p class="details-description"><%= movie.description %></p>

    <div class="action-row">
      <a href="/movies" class="btn btn-secondary">Back to Movies</a>

      <% if (currentUser && movie.owner && currentUser.id === movie.owner._id.toString()) { %>
        <a href="/movies/<%= movie._id %>/edit" class="btn btn-primary">Edit</a>
        <form action="/movies/<%= movie._id %>?_method=DELETE" method="POST" class="inline-form">
          <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this movie?')">Delete</button>
        </form>
      <% } %>
    </div>
  </div>
</section>
