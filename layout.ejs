<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MovieVault</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="navbar">
    <div class="container nav-flex">
      <a href="/" class="brand">🎬 MovieVault</a>
      <nav>
        <a href="/movies">Movies</a>
        <% if (currentUser) { %>
          <a href="/movies/new">Add Movie</a>
          <span class="welcome">Hi, <%= currentUser.name %></span>
          <form action="/logout" method="POST" class="inline-form">
            <button class="btn btn-outline" type="submit">Logout</button>
          </form>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register" class="btn btn-primary small-btn">Register</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container main-content">
    <% if (success && success.length) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>

    <% if (error && error.length) { %>
      <div class="alert alert-error"><%= error[0] %></div>
    <% } %>

    <%- body %>
  </main>

  <footer class="footer">
    <div class="container">
      <p>MovieVault Final Project • Express + EJS + Auth + CRUD Ready</p>
    </div>
  </footer>
</body>
</html>
